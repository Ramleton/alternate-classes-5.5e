{
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "editor.rulers": [80],
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "cSpell.words": [
    "blindsight",
    "darkvision",
    "ditem",
    "ethaks",
    "fvtt",
    "Geas",
    "halfling",
    "msak",
    "multiclass",
    "Multiclassing",
    "mwak",
    "Oathless",
    "premades",
    "Ramleton",
    "ronin",
    "rsak",
    "runecarver",
    "rwak",
    "Shadowdancer",
    "Spellbreaker",
    "spellcasting",
    "subrepos",
    "temphp",
    "tempmax",
    "tremorsense",
    "truesight",
    "warcry"
  ],
  "files.insertFinalNewline": false,
  "js/ts.preferences.importModuleSpecifierEnding": "js",
  "js/ts.tsserver.maxMemory": 4096
}
