{
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "triggerTaskOnSave.tasks": {
    "Generate Macro Index": ["src/scripts/**/*.ts"]
  },
  "editor.rulers": [80],
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "cSpell.words": [
    "adriangaro",
    "auraeffects",
    "blindsight",
    "bonebreaking",
    "Counterspell",
    "darkvision",
    "ditem",
    "esmodules",
    "ethaks",
    "fantasycalendar",
    "fullkey",
    "fvtt",
    "Geas",
    "halfling",
    "msak",
    "multiclass",
    "Multiclassing",
    "mwak",
    "nodamage",
    "Oathless",
    "premades",
    "Psiblade",
    "Psiknife",
    "publicroll",
    "Ramleton",
    "ronin",
    "rsak",
    "runecarver",
    "rwak",
    "Shadowdancer",
    "Spellbane",
    "spellblades",
    "Spellbreaker",
    "spellcasting",
    "subrepos",
    "TARC",
    "temphp",
    "tempmax",
    "TPAR",
    "tremorsense",
    "truesight",
    "warcry"
  ],
  "files.insertFinalNewline": false,
  "js/ts.preferences.importModuleSpecifierEnding": "js",
  "js/ts.tsserver.maxMemory": 4096
}
