{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "outDir": "dist/macros",
    "rootDir": "macros",
    "declaration": false,
    "sourceMap": true,
    "noEmitOnError": false,
    "typeRoots": [
      "types",
      "node_modules/@types"
    ]
  },
  "include": [
    "macros/**/*.ts",
    "macros/**/*.js",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "macros/**/DIME/**",
    "**/*.test.ts"
  ]
}