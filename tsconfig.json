{
  "compilerOptions": {
    "target": "es2025",
    "module": "es2022",
    "lib": [
      "DOM",
      "ESNext"
    ],
    "allowJs": true,
    "checkJs": false,
    "useDefineForClassFields": true,
    "resolveJsonModule": true,
    "sourceMap": false,
    "rootDir": "./src",
    "outDir": "./dist/src",
    "declarationDir": "./types",
    "declaration": true,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "isolatedModules": false,
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "noImplicitThis": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": false,
    "noImplicitOverride": false,
    "moduleResolution": "bundler",
    "paths": {
      "@midi-qol/types/*": [
        "./subrepos/midi-qol/types/*"
      ],
      "@midi-qol/types/module/*": [
        "./subrepos/midi-qol/types/module/*"
      ],
      "fvtt-types/*": [
        "./src/types/fvtt-types/*"
      ],
      "chris-premades/*": [
        "./src/types/chris-premades/*"
      ],
      "exploits/*": [
        "./src/scripts/exploits/*"
      ],
      "martialArts/*": [
        "./src/scripts/martialArts/*"
      ],
      "automation/*": [
        "./src/scripts/automation/*"
      ],
      "types/*": [
        "./src/types/*"
      ]
    },
    "types": [
      "@ethaks/fvtt-quench",
      "fvtt-types",
    ],
    "esModuleInterop": true,
    "newLine": "lf",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src",
    "src/types/chris-premades.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "subrepos/*"
  ],
}